{
  "manifest_version": 3,
  "name": "Polylight",
  "version": "3.0.0",
  "description": "Smooth rainbow text selection highlighting for every website.",
  "icons": {
    "128": "icons-1.28x.png",
    "512": "icons-5.12x.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Polylight",
    "default_icon": "icons-1.28x.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "rainbow-highlight@polylight.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
